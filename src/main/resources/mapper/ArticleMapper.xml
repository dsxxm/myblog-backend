<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.baka.xxm.repository.ArticleRepository">

  <resultMap id="BaseResultMap" type="com.baka.xxm.entity.Article">
      <id property="id" column="id" />
      <result property="title" column="title" />
      <result property="slug" column="slug" />
      <result property="summary" column="summary" />
      <result property="content" column="content" />
      <result property="author" column="author" />
      <result property="created_at" column="created_at" />
      <result property="updated_at" column="updated_at" />
  </resultMap>

  <select id="count" resultType="long">
    select count(*) from articles
  </select>

  <sql id="AllColumns">
    id,title,slug,summary,content,author,created_at,updated_at
  </sql>
  <select id="selectList" resultMap="BaseResultMap">
    select <include refid="AllColumns"/> from articles
    order by id desc
    limit #{limit} offset #{offset}
  </select>
  <select id="selectById" resultMap="BaseResultMap">
    select <include refid="AllColumns"/> from articles 
    where id = #{id}
  </select>
  
  <sql id="InsertColumns">
    title,slug,summary,content,author
  </sql>
  <sql id="InsertValues">
    #{title},#{slug},#{summary},#{content},#{author}
  </sql>
  <insert id="insert">
    insert into articles (<include refid="InsertColumns"/>) 
    values (<include refid="InsertValues"/>)
  </insert>

  <update id="update">
    update articles
    set title=#{title}, slug=#{slug}, summary=#{summary}, content=#{content}, author=#{author}
    where id=#{id}
  </update>

  <delete id="delete">
    delete from articles
    where id=#{id}
  </delete>
</mapper>
